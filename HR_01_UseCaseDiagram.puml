@startuml HR_01_UseCaseDiagram
!pragma layout smetana
title KSRTC HR & Payroll System - Business Overview

 left to right direction
 skinparam packageStyle rectangle

 actor "System Admin / HR" as Admin
 actor "Manager / Approver" as Manager
 actor "Employee / Staff" as Emp
  
   rectangle "KSRTC HR & Payroll System" {
  
     package "1. MASTER (Setup)" {
       usecase "Register Staff" as UC_RegStaff
       usecase "Update Details" as UC_UpdateEmp
       usecase "Manage Status" as UC_ManageStatus
       usecase "Manage Cost Centers" as UC_ManageCC
       usecase "Configure Salary Master" as UC_ConfigSal
     }
  
     package "2. TASKS (Operations)" {
       usecase "Manual Attendance Import" as UC_ManualAtt
       usecase "Mark Daily Attendance" as UC_MarkAtt
       usecase "Submit Leave Request" as UC_SubmitLeave
       usecase "Approve/Reject Leave" as UC_ApproveLeave
       usecase "Execute Payroll Engine" as UC_ExecPayroll
     }
  
     package "3. REPORTS (Monitoring)" {
       usecase "Generate Reports\n(Ledger/Register)" as UC_GenReports
       usecase "View Personal Payslips" as UC_ViewPayslip
       usecase "View Leave Balance" as UC_ViewLeaveBal
     }
   }

' Interactions
Admin --> UC_RegStaff
Admin --> UC_UpdateEmp
Admin --> UC_ManageStatus
Admin --> UC_ManageCC
Admin --> UC_ConfigSal
Admin --> UC_ExecPayroll
Admin --> UC_GenReports
Admin --> UC_ManualAtt

Manager --> UC_ApproveLeave
Manager --> UC_GenReports

Emp --> UC_MarkAtt
Emp --> UC_SubmitLeave
Emp --> UC_ViewPayslip
Emp --> UC_ViewLeaveBal

' Dependencies
UC_ExecPayroll ..> UC_MarkAtt : <<include>>

@enduml
