@startuml HR_02_PayrollWorkflow
title KSRTC - Complex Payroll Execution Engine

skinparam backgroundColor #FFFFFF
skinparam activity {
  BackgroundColor #E3F2FD
  BorderColor #003399
  ArrowColor #003399
  StartColor #003399
  EndColor #003399
  DiamondBackgroundColor #FFFDE7
  DiamondBorderColor #FBC02D
}

start
:HR Administrator selects Target Month and Year;
:System validates existing **Payroll Runs**;

if (Is Period Already Processed?) then (Yes)
  :System displays **Validation Error**;
  stop
else (No)
  :System initializes new Run (Status = **DRAFT**);
  :Fetch all **ACTIVE** Employees from Master DB;
  
  while (Iterate through Employees) is (Remaining)
    :Data Input: Fetch **Salary Grade & Base Pay**;
    :Data Input: Fetch **Attendance Logs** (Present, Leave, LOP);
    :Calculate Total Payable Days;
    
    fork
      :Calculate Earnings:
      - Pro-rated Base Salary
      - HRA (House Rent Allowance)
      - Conveyance & Medical;
    fork again
      :Calculate Deductions:
      - PF (12% of Base)
      - ESI & Professional Tax
      - Unpaid Leave Deductions;
    end fork
    
    :Calculate **Net Pay** (Earnings - Deductions);
    :Generate **Salary Slip** Database Record;
  endwhile (Done)
  
  :System updates Payroll Run status to **PROCESSED**;
  :System commits all transactional data;
  :Generate **Monthly Salary Ledger**;
  :HR Administrator views **SUCCESS** Summary;
endif

stop
@enduml
